# Backend
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="http://localhost:3000"
JWT_SECRET="generate-a-long-random-secret"

# Supabase frontend (valores públicos)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Supabase backend (nunca use VITE_ nesta chave)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Opcional, somente desenvolvimento local sem Supabase.
# Nunca habilitado em produção.
ALLOW_LOCAL_AUTH="false"

# Obrigatórias apenas se ALLOW_LOCAL_AUTH=true
# LOCAL_ADMIN_EMAIL="admin@localhost"
# LOCAL_ADMIN_PASSWORD="use-a-strong-development-password"
# LOCAL_ADMIN_NAME="Administrador Local"
